{
  "name": "finnews-monitor",
  "version": "1.0.0",
  "description": "金融新闻监控助手 - 自动追踪新闻源，根据持仓智能筛选，邮件分级推送",
  "main": "dist/app.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/app.js",
    "dev": "ts-node src/app.ts",
    "dev:watch": "nodemon --exec ts-node src/app.ts"
  },
  "keywords": [
    "finance",
    "news",
    "monitor",
    "rss",
    "email"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "lru-cache": "^10.1.0",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.9.8",
    "rss-parser": "^3.13.0",
    "turndown": "^7.1.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/node-schedule": "^2.1.5",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "@types/xml2js": "^0.4.14",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
